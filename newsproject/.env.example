# Copy this file to .env and fill in your values.
# .env is git-ignored – never commit real secrets.

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=newsproject.settings.development

# Database (matches docker-compose service 'db')
DB_NAME=news_db
DB_USER=news_user
DB_PASSWORD=change_me
DB_HOST=db
DB_PORT=5432

# Redis (matches docker-compose service 'redis')
REDIS_URL=redis://redis:6379/0

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (SMTP)
E_HOST=smtp.gmail.com
E_PORT=587
E_NAME=your-email@gmail.com
E_PASSWORD=your-app-password

# Production only
ALLOWED_HOSTS=your-domain.com
